rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Plans ---
    match /plans/{planId} {
      function isValidPlan(data) {
        return data.id is string && data.id.size() <= 10 &&
               data.type in ['day', 'month'] &&
               data.createdAt == request.time &&
               data.expiresAt > request.time;
      }

      allow get: if isSignedIn() && isValidId(planId);
      allow create: if isSignedIn() && isValidId(planId) && isValidPlan(incoming());
      
      allow update: if isSignedIn() && 
        incoming().createdAt == existing().createdAt &&
        incoming().id == existing().id &&
        incoming().type == existing().type;

      allow delete: if isSignedIn() && (existing().creatorId == request.auth.uid || existing().creatorId == 'anonymous');

      // --- Participants ---
      match /participants/{participantId} {
        function isValidParticipant(data) {
          return data.displayName is string && data.displayName.size() <= 40 &&
                 data.availability is list && data.availability.size() <= 200 &&
                 data.lastActive == request.time;
        }

        allow list: if isSignedIn(); // Restricted by path
        allow get: if isSignedIn();
        
        allow create: if isSignedIn() && 
                      participantId == request.auth.uid && 
                      isValidParticipant(incoming());
        
        allow update: if isSignedIn() && 
                      participantId == request.auth.uid &&
                      isValidParticipant(incoming());

        allow delete: if isSignedIn() && participantId == request.auth.uid;
      }
    }
  }
}
